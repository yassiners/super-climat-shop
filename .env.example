# Ce fichier contient les variables d'environnement nécessaires pour le projet, sans valeur réelle.
# Copiez ce fichier sous le nom .env.local et renseignez vos propres informations.

# PostgreSQL via Supabase + pgbouncer
DATABASE_URL="postgresql://username:password@host:port/database?pgbouncer=true"
DIRECT_URL="postgresql://username:password@host:port/database"

# NextAuth config
NEXTAUTH_SECRET="your_nextauth_secret_here"
NEXTAUTH_URL="http://localhost:3000"

# Supabase Storage Configuration
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE"

# Email Configuration pour le formulaire de contact (SMTP)
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-email-app-password"
